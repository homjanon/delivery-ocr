# 复制本文件为 .env 并填入你的 Key（.env 不要提交到任何公开仓库）
# PROVIDER 可选: zhipu / qwen35b / sensenova
PROVIDER=zhipu

# 智谱 GLM-4.6V-Flash
ZHIPU_API_KEY=

# 硅基流动 Qwen3.5-35B-A3B
SILICONFLOW_API_KEY=

# 商汤 SenseNova（后端直连，无浏览器 CORS 限制；需按官方文档核对模型名）
SENSENOVA_API_KEY=

# 商汤模型名覆盖（可选，默认 SenseNova-V6.7-Flash-Lite，以官方文档为准）
# SENSENOVA_MODEL=SenseNova-V6.7-Flash-Lite
